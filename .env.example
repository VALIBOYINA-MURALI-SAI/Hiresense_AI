# =============================================================================
# Hire Sense AI — environment template (safe to commit; no real secrets)
# =============================================================================
#
# LOCAL DEVELOPMENT
# -----------------
# 1. Copy this file to `.env` in the project root (recommended), and/or to
#    `utils/.env` — the app loads root `.env` first, then `utils/.env` (wins on
#    duplicate keys). See `bootstrap_env.py`.
# 2. Fill in at least GOOGLE_API_KEY for the AI resume analyzer (Gemini).
# 3. OAuth (Google/GitHub sign-in) is OPTIONAL locally: you can skip OAuth
#    setup and use HIRERESUME_SKIP_LOGIN=1 for faster dev, or test OAuth with
#    localhost redirect URIs in your Google/GitHub app settings.
#
# STREAMLIT CLOUD (deployed app)
# ------------------------------
# Put sensitive values in the Cloud dashboard: App → Settings → Secrets (TOML).
# Do NOT rely on .env on the server — it is not deployed from git.
#   - GOOGLE_API_KEY / OPENROUTER_API_KEY → Secrets (or set in the dashboard)
#   - OAuth client IDs/secrets, redirect URI → Secrets only (the app reads
#     oauth_* from st.secrets for token exchange; see utils/oauth_login.py)
#   - admin_email / admin_password → Secrets only (seeds admin when DB is empty)
#   - require_user_oauth → Secrets if you want to force login on Cloud
#
# Never commit real API keys or passwords. Rotate anything that was ever exposed.
# =============================================================================

# --- AI (required for resume analysis) ---------------------------------------
GOOGLE_API_KEY=
# Optional: OpenRouter for alternate models
OPENROUTER_API_KEY=

# Gemini transport: rest (default on Windows) or grpc
# GOOGLE_GENAI_TRANSPORT=rest

# --- Gemini free tier (defaults match code; omit to use them) -----------------
# Multiple models recommended: free tier limits are often per-model per day (~20 RPD each).
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite
# GEMINI_MAX_OUTPUT_TOKENS=4096
# HIRERESUME_RESUME_MAX_CHARS=12000
# HIRERESUME_JOB_DESC_MAX_CHARS=3000
# HIRERESUME_VERBOSE_GEMINI_PROMPT=0

# --- Local dev convenience (do NOT enable on production Cloud) -------------
# Skip the sign-in page while developing (localhost only).
# HIRERESUME_SKIP_LOGIN=1

# Require OAuth when credentials exist (env or secrets). On Cloud, prefer secrets.
# HIRERESUME_REQUIRE_USER_OAUTH=1

# --- OAuth (optional locally; use Streamlit Secrets on Cloud) ----------------
# For local OAuth testing, set redirect to e.g. http://localhost:8501/
# The app reads redirect from env so localhost can override Cloud URLs.
# OAUTH_REDIRECT_URI=http://localhost:8501/
# oauth_redirect_uri=https://your-app.streamlit.app

# These are read from st.secrets in production; .env entries help some local flows.
# oauth_google_client_id=
# oauth_google_client_secret=
# oauth_github_client_id=
# oauth_github_client_secret=

# --- Admin (Cloud: use Secrets) ---------------------------------------------
# Local-only if you extend the app to read these; Cloud uses st.secrets.
# admin_email=
# admin_password=

# --- TLS / corpus (optional) -------------------------------------------------
# HIRERESUME_SKIP_CA_BUNDLE=0
# HIRERESUME_USE_CERTIFI_ONLY=0
# RESUME_CORPUS_ROOT=

# --- Other -------------------------------------------------------------------
# HIRERESUME_ENABLE_ROLE_PRIORS=0
# HIRERESUME_LOGIN_SPOTLIGHT_TRUST_PCT=
# HIRERESUME_LOGIN_SPOTLIGHT_EXPERIENCE_PCT=
